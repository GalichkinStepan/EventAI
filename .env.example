# Скопируйте в .env и подставьте свои значения (файл .env не коммитьте)
BOT_TOKEN=0000000000:YOUR_BOT_TOKEN_HERE

# PostgreSQL (asyncpg)
DATABASE_URL=postgresql://user:password@localhost:5432/telegram_bot

# Cerebras Inference (https://cloud.cerebras.ai/ — API key)
CEREBRAS_API_KEY=
# Список моделей: https://inference-docs.cerebras.ai/models/overview
CEREBRAS_MODEL=llama3.1-8b

# Администратор(ы): числовые Telegram user id через запятую (узнать: @userinfobot)
ADMIN_TELEGRAM_IDS=
# Допустимо вместо списка один id:
# TELEGRAM_ID=123456789
# ADMIN_ID=123456789

# VK API (для ссылок vk.com / vk.ru в aggregator_links): токен с доступом к wall
# https://dev.vk.com/api/access-token/user-token
VK_ACCESS_TOKEN=

# Мероприятия из постов VK / публичных Telegram-каналов (через Cerebras)
EVENTS_SYNC_ENABLED=1
EVENTS_SYNC_INTERVAL_HOURS=12
EVENTS_FETCH_DAYS=2

# --- Webhook (хостинг: Render и др.) ---
# Если задан WEBHOOK_URL — бот работает через webhook + aiohttp (не polling).
# Пример для Render: публичный URL сервиса + путь, на который Telegram шлёт POST:
#   WEBHOOK_URL=https://your-bot-name.onrender.com/webhook
# Секрет для заголовка X-Telegram-Bot-Api-Secret-Token (рекомендуется в продакшене):
#   WEBHOOK_SECRET=случайная_длинная_строка
# Порт HTTP: на Render переменная PORT подставляется платформой — не задавайте вручную.
# PORT=8080
# Локально с polling: не указывайте WEBHOOK_URL или поставьте USE_POLLING=1
# (чтобы временно игнорировать WEBHOOK_URL в .env).
# USE_POLLING=1
